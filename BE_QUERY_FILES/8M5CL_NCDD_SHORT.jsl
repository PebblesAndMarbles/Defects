        <Operation>E_8M5_HM_ETCH</Operation>
        <Parameters>OPERATION,LOT_RECIPE,TIME_BETWEEN</Parameters>
        <PriorLevel>BATCH</PriorLevel>
        <RollupLevel>WAFER</RollupLevel>
        <UseOperationAliasConfig>1</UseOperationAliasConfig>
      </Query>
      <Query>
        <TaskName>WaferEntity</TaskName>
        <DescriptionInColumnName>1</DescriptionInColumnName>
        <DescriptionType>ALIAS</DescriptionType>
        <Operation>L_8M5_SED</Operation>
        <ParameterList>ENTITY,RETICLE</ParameterList>
        <RollupLevel>WAFER</RollupLevel>
        <UseOperationAliasConfig>1</UseOperationAliasConfig>
      </Query>
      <Query>
        <TaskName>LotSIFData</TaskName>
