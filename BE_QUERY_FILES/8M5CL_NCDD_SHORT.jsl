        <ReworkFrom>0</ReworkFrom>
        <RollupLevel>WAFER</RollupLevel>
        <StartsParameters>PRODUCT,ROUTE</StartsParameters>
        <UseOperationAliasConfig>1</UseOperationAliasConfig>
      </Query>
      <Query>
        <TaskName>DefectParameterQuery</TaskName>
        <DropUnscanned>1</DropUnscanned>
        <Layer></Layer>
        <LayerColumn>1</LayerColumn>
