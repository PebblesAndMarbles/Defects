      </Query>
      <Query>
        <TaskName>PMCounterDataByLot</TaskName>
        <AttributeLevels>ENTITY,CHAMBER,SUBENTITY</AttributeLevels>
        <Attributes></Attributes>
        <CounterData>1</CounterData>
        <DescriptionInColumnName>1</DescriptionInColumnName>
        <DescriptionType>ALIAS</DescriptionType>
        <MultiLayer>0</MultiLayer>
        <NDaysOffset>1</NDaysOffset>
        <Operation>E_8M5_HM_ETCH</Operation>
        <RollupLevel>WAFER</RollupLevel>
        <UseOperationAliasConfig>1</UseOperationAliasConfig>
      </Query>
      <Query>
        <TaskName>EntityUtilization</TaskName>
        <Component>SUBENTITY</Component>
        <DescriptionInColumnName>1</DescriptionInColumnName>
        <DescriptionType>ALIAS</DescriptionType>
        <Operation>E_8M5_HM_ETCH</Operation>
        <Parameters>PROCESS_TIME,N_WAFERS,PERCENT_UTILIZATION</Parameters>
        <RollupLevel>WAFER</RollupLevel>
        <TimeWindow>12</TimeWindow>
