window_title = "Surf Scan Fleet Report";
bycol = "EVENT";
xcol = "INSPECTION_TIME";
ycol = "ADDER_DEFECTS";
legendcol1 = "PRIMARY_EQUIP";
vcol = "PRIMARY_EQUIP";

ymin = -1;
ymax = 10;
inc = 5;
