seg_events = {"M_GO_ALL_SEG", "M_GO_C_SEG", "M_GO_E_SEG", "M_GO_M_SEG", "M_LIFT10X_SEG", "M_MECH_CYCLE_SEG", "M_SFV10X_SEG"};
ss_events = {"SS0", "SS1", "SS7"};

Get_Source_Columns = Function({source_path}, {Default Local},
    _preview_cols = {};
    Try(
        _preview_dt = Open(source_path, Invisible);
        _preview_cols = _preview_dt << Get Column Names("String");
        Close(_preview_dt, NoSave);
    ,
        _preview_cols = {};
    );
    _preview_cols;
);

Build_Available_Columns = Function({}, {Default Local},
    _cols = Get_Source_Columns(metrics_path);
    If(N Items(_cols) == 0,
        _cols = {"PRIMARY_EQUIP", "EVENT", "ACTUAL_LOT", "LOT7", "LAYER", "PILOT"};
    );
    If(Contains(_cols, "PRIMARY_EQUIP"),
        Remove From(_cols, Contains(_cols, "PRIMARY_EQUIP"));
        Insert Into(_cols, "PRIMARY_EQUIP", 1);
    );
    If(!Contains(_cols, "PILOT"),
        Insert Into(_cols, "PILOT");
    );
    _cols;
);

Ensure_Pilot_Column = Function({table_obj},
    _cols = table_obj << Get Column Names("String");
    If(Contains(_cols, "PILOT"),
        Return();
    );

    _has_srcip = Contains(_cols, "SRCIP");
    _has_ccmr2 = Contains(_cols, "CCMR2");
    _has_iccr2 = Contains(_cols, "ICCR2");

    If(_has_srcip & _has_ccmr2 & _has_iccr2,
        table_obj << New Column("PILOT", Character, Nominal,
            Set Each Value(
                _srcip = Char(Column(table_obj, "SRCIP")[Row()]);
                _ccmr2 = Char(Column(table_obj, "CCMR2")[Row()]);
                _iccr2 = Char(Column(table_obj, "ICCR2")[Row()]);
                If(_srcip == "ON",
                    "SRCIP",
                    _ccmr2 == "ON",
                    "CCMR2",
                    _srcip == "OFF" & _ccmr2 == "OFF" & _iccr2 == "ON",
                    "ICCR2",
                    "POR"
                )
            )
        );
    ,
        table_obj << New Column("PILOT", Character, Nominal, Set Each Value(""));
    );
);

available_cols = Build_Available_Columns();

val_cb_close_reports_and_windows = 0;
val_no_splines = 0;
val_black_wafermap_markers = 0;
val_hide_status = 4;
val_source_index = 1;
val_legendcol1 = "PRIMARY_EQUIP";
val_event_mode = 1;
val_debug_layout = 0;
selected_source_name = "Most recent 60 days";
val_yymm_lookback_periods = 12;
yymm_cutoff_value = .;

Normalize_YYMM_Value = Function({raw_value}, {Default Local},
    _raw_char = Trim(Char(raw_value));
    If(_raw_char == "" | _raw_char == ".",
        Return(.);
    );
    _num = Num(_raw_char);
    If(Is Missing(_num),
        Return(.);
    );
    Round(_num, 1);
);

YYMM_To_Period_Index = Function({yymm_value}, {Default Local},
    _yymm_num = Normalize_YYMM_Value(yymm_value);
    If(Is Missing(_yymm_num),
        Return(.);
    );
    _yy = Floor(_yymm_num / 100);
    _mm = Mod(_yymm_num, 100);
    If(_mm < 1 | _mm > 12,
        Return(.);
    );
    (_yy * 12) + (_mm - 1);
);

Period_Index_To_YYMM = Function({period_index}, {Default Local},
    If(Is Missing(period_index),
        Return(.);
    );
    _yy = Floor(period_index / 12);
    _mm = Mod(period_index, 12) + 1;
    (_yy * 100) + _mm;
);

Parse_Lookback_Periods = Function({raw_text, default_value}, {Default Local},
    _text_num = Num(Trim(Char(raw_text)));
    If(Is Missing(_text_num) | _text_num < 1,
        Return(default_value);
    );
    Max(1, Floor(_text_num));
);

Get_Max_YYMM_From_Table = Function({table_obj}, {Default Local},
    _cols = table_obj << Get Column Names("String");
    If(!Contains(_cols, "YYMM"),
        Return(.);
    );
    _max_period_index = .;
    For(_r = 1, _r <= N Rows(table_obj), _r++,
        _period_index = YYMM_To_Period_Index(Column(table_obj, "YYMM")[_r]);
        If(!Is Missing(_period_index),
            If(Is Missing(_max_period_index),
                _max_period_index = _period_index,
                _max_period_index = Max(_max_period_index, _period_index)
            );
        );
    );
    Period_Index_To_YYMM(_max_period_index);
);

Apply_YYMM_Lookback_Filter = Function({table_obj, cutoff_period_index}, {Default Local},
    _cols = table_obj << Get Column Names("String");
    If(!Contains(_cols, "YYMM") | Is Missing(cutoff_period_index),
        Return(0);
    );
    table_obj << Select Where(
        Is Missing(YYMM_To_Period_Index(Column(table_obj, "YYMM")[Row()])) |
        YYMM_To_Period_Index(Column(table_obj, "YYMM")[Row()]) < cutoff_period_index
    );
    _n_removed = N Row(table_obj << Get Selected Rows);
    If(_n_removed > 0,
        table_obj << Delete Rows;
    );
    table_obj << Clear Select;
    _n_removed;
);

Print(
    "SURF SCAN FLEET BUILD: 2026-04-27E | event_mode_default=" || Char(val_event_mode) ||
    " | debug_layout=" || Char(val_debug_layout) ||
    " | varchart_group_width=" || Char(varchart_group_width)
);

