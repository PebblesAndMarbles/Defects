If(val_source_index == 1,
    cutoff_dt = Date Increment(Today(), "Day", -60);
    dt << Select Where(:INSPECTION_TIME >= cutoff_dt);
    dt_recent = dt << Subset(Selected Rows, Output Table("SS Metrics - Recent 60 Days"), Invisible);
    dt << Clear Select;
    Close(dt, NoSave);
    dt = dt_recent;

    dt_coords << Select Where(:INSPECTION_TIME >= cutoff_dt);
    dt_coords_recent = dt_coords << Subset(Selected Rows, Output Table("SS Coordinates - Recent 60 Days"), Invisible);
    dt_coords << Clear Select;
    Close(dt_coords, NoSave);
    dt_coords = dt_coords_recent;
,
    If(val_source_index == 3,
        _max_yymm = Get_Max_YYMM_From_Table(dt);
        _max_period_index = YYMM_To_Period_Index(_max_yymm);
        If(!Is Missing(_max_period_index),
            _yymm_cutoff_period_index = _max_period_index - (val_yymm_lookback_periods - 1);
            yymm_cutoff_value = Period_Index_To_YYMM(_yymm_cutoff_period_index);
            _removed_dt_rows = Apply_YYMM_Lookback_Filter(dt, _yymm_cutoff_period_index);
            _removed_coord_rows = Apply_YYMM_Lookback_Filter(dt_coords, _yymm_cutoff_period_index);
            Print(
                "YYMM lookback filter applied - periods=" || Char(val_yymm_lookback_periods) ||
                " max_yymm=" || Char(_max_yymm) ||
                " cutoff_yymm=" || Char(yymm_cutoff_value) ||
                " removed_rows(metrics,coords)=(" || Char(_removed_dt_rows) || "," || Char(_removed_coord_rows) || ")"
            );
            selected_source_name = selected_source_name || " cutoff>= " || Char(yymm_cutoff_value);
        ,
            Print("YYMM lookback requested but no valid YYMM values were found; leaving tables unfiltered.");
        );
    );
);

Ensure_Pilot_Column(dt);

