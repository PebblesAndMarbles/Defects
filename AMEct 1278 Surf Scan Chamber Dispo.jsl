result = New Window( "Surf Scan Chamber Report Options", <<Modal, <<Return Result,
    V List Box(
        Lineup Box(N Col(1),
            Panel Box("CSV SOURCE",
                rbSource = Radio Box(
                    {"Most recent 60 days", "Full integrated", "YYMM lookback"}
                ),
                H List Box(
                    Text Box("YYMM periods:"),
                    yymmLookbackTB = Text Edit Box("12", <<Set Width(40))
                )
            ),
            Panel Box("SELECT TEAM MEMBER",
                rbChamber = Radio Box( {"Trey", "Kayden", "Chang", "Adi", "Travis", "Tyler", "Mathius", "Sashank", "William", "Minog"} )
            ),
            Panel Box("SINGLE CHAMBER OVERRIDE (supersedes team member selection)",
                Lineup Box(N Col(7),
                    Text Box( "AME4" ), ENTITY_TB = Text Edit Box( "", <<Set Width( 25 ) ),
                    Text Box( "_PM" ), PM_TB = Text Edit Box( "", <<Set Width( 12 ) ),
                    Spacer Box(Size(10, 10)),
                    Text Box( "  or full PRIMARY_EQUIP list:" ), SUBENTITY_TB = Text Edit Box( "", <<Set Width( 150 ) )
                )
            ),
            Panel Box("OPTIONS",
                cb_close_reports_and_windows = Check Box( "Close Reports & Windows" ),
                cb_show_fleet = Check Box( "Show FLEET Coordinates" ),
                cb_black_wafermap_markers = Check Box( "Black Wafermap Markers" )
            ),
            Panel Box("EVENT MODE",
                rbEventMode = Radio Box(
                    {"SS only", "SEG only", "SS and SEG"}
                )
            ),
            Panel Box("HIGHFLIER / BASELINE FILTER",
