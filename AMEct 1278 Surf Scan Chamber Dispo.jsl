                    {"Hide Highfliers NOT in chamber list",
                     "Hide ALL Highfliers",
                     "Hide BASELINE rows",
                     "Hide / Exclude nothing (show all rows)"}
                )
            ),
            Button Box( "OK",
                val_cb_close_reports_and_windows = cb_close_reports_and_windows << Get;
                val_show_fleet = cb_show_fleet << Get;
                val_black_wafermap_markers = cb_black_wafermap_markers << Get;
                val_hide_status = rbHideStatus << Get;
                val_source_index = rbSource << Get;
                val_event_mode = rbEventMode << Get;
                val_yymm_lookback_periods = Parse_Lookback_Periods(yymmLookbackTB << Get Text, 12);

                If(val_source_index == 2,
                    selected_source_name = "Full integrated";
                ,
                    If(val_source_index == 3,
                        selected_source_name = "YYMM lookback (" || Char(val_yymm_lookback_periods) || " periods)";
                    ,
                        selected_source_name = "Most recent 60 days";
                    );
                );

                SUBENTITY_STR = Trim(SUBENTITY_TB << Get Text());
                If(SUBENTITY_STR != "",
                    chamber_list = Words(SUBENTITY_STR, ",");
                    For(i = 1, i <= N Items(chamber_list), i++,
                        chamber_list[i] = Trim(chamber_list[i]);
                    );
                    selected_member = "CUSTOM: " || SUBENTITY_STR;
                ,
                    ENTITY_STR = Trim(ENTITY_TB << Get Text());
                    PM_STR = Trim(PM_TB << Get Text());
                    If(ENTITY_STR != "" & PM_STR != "",
                        CHAMBER_STR = "AME4" || ENTITY_STR || "_PM" || PM_STR;
                        chamber_list = {};
                        Insert Into(chamber_list, CHAMBER_STR);
                        selected_member = "CUSTOM: " || CHAMBER_STR;
                    ,
                        val_chamber_index = rbChamber << Get;
                        chamber_list = chamber_data[val_chamber_index][2];
                        selected_member = chamber_data[val_chamber_index][1];
                    );
                );

                {val_cb_close_reports_and_windows, val_hide_status, val_show_fleet, val_source_index, val_black_wafermap_markers, val_event_mode, val_yymm_lookback_periods}
            )
        )
    )
);

